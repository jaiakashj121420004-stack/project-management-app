{
  "name": "aurora",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Aurora — a modern, installable PWA project-management app (Kanban, calendar, notes, collaboration).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
