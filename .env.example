# Aurora — frontend environment variables.
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
# Both vars are PUBLIC (the anon key is safe in the browser — Row Level
# Security protects the data; see plan.md §6). The Supabase service_role key
# must NEVER appear here or anywhere in the frontend.
#
# Find these in your Supabase dashboard: Settings → API.

# Your Supabase project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# Your Supabase public anon key (starts with "eyJ...")
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# That's all the frontend needs. The Phase 9 EMAIL REMINDERS feature uses
# server-side secrets (RESEND_API_KEY, REMINDER_FROM_EMAIL, CRON_SECRET) that
# live ONLY in the Supabase dashboard (Edge Function secrets) — they are NOT
# VITE_ vars and must NEVER be added here or shipped to the browser. Setup:
# supabase/README.md → "Due-date email reminders".
# ---------------------------------------------------------------------------
